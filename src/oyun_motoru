interface SesSistemi {
    void efektOynat(String isim);
}

class SesAdaptoru implements SesSistemi {
    private DisSesEfektMotoru disMotor;

    public SesAdaptoru(DisSesEfektMotoru motor) {
        this.disMotor = motor;
    }

    @Override
    public void efektOynat(String isim) {
        disMotor.sesCal(isim, 100);
    }
}
