abstract class OyunNesnesi {
    public String nesneAdi;
    public int canDegeri;
    public int yatayKonum;
    public int dikeyKonum;
    public int guc;

    public abstract void hareketEt(string yon,int miktar);
    public abstract void saldir(OyunNesnesi hedef);}
    class oyuncu extends OyunNesnesi{
        public oyuncu(String ad,int can,int x,int y,int kuvvet){
            this.nesneAdi=ad;
            this.canDegeri=can;
            this.yatayKonum=x;
            this.dikeyKonum=y;
            this.guc=kuvvet;
        }
        @Override
        public void hareketEt(String yon, int miktar) {
            if (yon.equals("ileri")) {
                dikeyKonum += miktar;
            } else if (yon.equals("sag")) {
                yatayKonum += miktar;
            }
        }

        @Override
        public void saldir(OyunNesnesi hedef) {
            if (hedef.nesneTipi == Tip.DUSMAN) {
                hedef.canDegeri -= guc;
            }
        }
    }
    class Dusman extends OyunNesnesi{
        public Dusman(String ad,int can,int x,int y,int kuvvet){
            this.nesneAdi=ad;
            this.canDegeri=can;
            this.yatayKonum=x;
            this.dikeyKonum=y;
            this.guc=kuvvet;
        }
        @Override
        public void hareketEt(String yon, int miktar) {
            if (canDegeri > 0) {
                yatayKonum -= (miktar / 2);
            }
        }

        @Override
        public void saldir(OyunNesnesi hedef) {
            if (hedef.nesneTipi == Tip.OYUNCU) {
                hedef.canDegeri -= (guc * 2);
            }
        }
    }
    class OyunNesnesiFabrikasi{
        public static Oyun Nesnesi nesneUret(String tip, String ad, int can, int x, int y, int guc) {
         if(tip.equalsIgnoreCase("OYUNCU")){
            return new Oyuncu(ad,can,x,y,guc)
         }   
         else if(tip.equalsIgnoreCase("DUSMAN")){
            return new Dusman(ad,can,x,y,guc)
         }
         return null;
    }

